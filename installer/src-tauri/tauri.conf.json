{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Second Brain Setup",
  "version": "0.4.0",
  "identifier": "com.sircharan.second-brain-setup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Second Brain Setup",
        "width": 720,
        "height": 700,
        "minWidth": 640,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Utility",
    "shortDescription": "Set up second-brain for Claude Code",
    "longDescription": "A friendly installer that wires the second-brain plugin into Claude Code and opens your local Markdown vault in Obsidian.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
